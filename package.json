{
  "name": "line-count-statusbar",
  "displayName": "Line Count Status Bar",
  "description": "Shows total line count of the current file in the status bar",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "lines",
    "count",
    "status bar",
    "file info"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Line Count Status Bar",
      "properties": {
        "lineCount.showInStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show line count in status bar"
        },
        "lineCount.format": {
          "type": "string",
          "default": "Lines: $(symbol-number) {count}",
          "description": "Format string for displaying line count. Use {count} as placeholder."
        },
        "lineCount.alignment": {
          "type": "string",
          "enum": [
            "left",
            "right"
          ],
          "default": "left",
          "description": "Status bar alignment"
        },
        "lineCount.priority": {
          "type": "number",
          "default": 100,
          "description": "Status bar item priority (higher = more left)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "18.x",
    "typescript": "^4.9.4"
  },
  "author": "Your Name",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  }
}
